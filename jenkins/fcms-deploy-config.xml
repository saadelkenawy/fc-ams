<?xml version='1.1' encoding='UTF-8'?>
<flow-definition plugin="workflow-job">
  <description>CD Pipeline — pulls :latest images from Docker Hub and deploys locally. Auto-triggered by fcms-pipeline on success.</description>
  <keepDependencies>false</keepDependencies>

  <properties>
    <!-- Disallow concurrent runs to prevent overlapping deploys -->
    <org.jenkinsci.plugins.workflow.job.properties.DisableConcurrentBuildsJobProperty>
      <abortPrevious>false</abortPrevious>
    </org.jenkinsci.plugins.workflow.job.properties.DisableConcurrentBuildsJobProperty>

    <!-- Parameters declared here mirror the Jenkinsfile.deploy parameters block -->
    <hudson.model.ParametersDefinitionProperty>
      <parameterDefinitions>

        <hudson.model.ChoiceParameterDefinition>
          <name>IMAGE_TAG</name>
          <description>Docker Hub tag to pull and deploy</description>
          <choices class="java.util.Arrays$ArrayList">
            <a class="string-array">
              <string>latest</string>
              <string>post-prod</string>
            </a>
          </choices>
        </hudson.model.ChoiceParameterDefinition>

        <hudson.model.ChoiceParameterDefinition>
          <name>DEPLOY_TARGET</name>
          <description>Where to deploy: local = this machine, pre-prod / production = remote via SSH</description>
          <choices class="java.util.Arrays$ArrayList">
            <a class="string-array">
              <string>local</string>
              <string>pre-prod</string>
              <string>production</string>
            </a>
          </choices>
        </hudson.model.ChoiceParameterDefinition>

        <hudson.model.StringParameterDefinition>
          <name>SERVICES</name>
          <defaultValue>all</defaultValue>
          <description>Comma-separated list of services to deploy, or "all" for everything</description>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>

      </parameterDefinitions>
    </hudson.model.ParametersDefinitionProperty>
  </properties>

  <definition class="org.jenkinsci.plugins.workflow.cps.CpsScmFlowDefinition"
               plugin="workflow-cps">
    <scm class="hudson.plugins.git.GitSCM" plugin="git">
      <configVersion>2</configVersion>
      <userRemoteConfigs>
        <hudson.plugins.git.UserRemoteConfig>
          <url>git@github.com:saadelkenawy/fc-ams.git</url>
          <!-- Remove or replace credentialsId if repo is public -->
          <credentialsId>github-ssh-key</credentialsId>
        </hudson.plugins.git.UserRemoteConfig>
      </userRemoteConfigs>
      <branches>
        <hudson.plugins.git.BranchSpec>
          <name>*/main</name>
        </hudson.plugins.git.BranchSpec>
      </branches>
      <doGenerateSubmoduleConfigurations>false</doGenerateSubmoduleConfigurations>
      <submoduleCfg class="empty-list"/>
      <extensions/>
    </scm>
    <scriptPath>Jenkinsfile.deploy</scriptPath>
    <lightweight>true</lightweight>
  </definition>

  <triggers/>
  <disabled>false</disabled>
</flow-definition>
