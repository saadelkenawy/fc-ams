NODE_ENV=development
PORT=3002
LOG_LEVEL=info

# PostgreSQL (Crunchy / PgBouncer)
DATABASE_URL=postgresql://fadl_app:secret@localhost:5432/fadl_clinic_production
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis (for distributed locks and session cache)
REDIS_URL=redis://localhost:6379

# JWT (issued by identity-service / Keycloak)
JWT_SECRET=change-me-use-vault-in-production
JWT_EXPIRY=15m

# Service identity
BRANCH_ID=1
SERVICE_NAME=appointment-service
