NODE_ENV=development
PORT=3012
LOG_LEVEL=info

# PostgreSQL (Crunchy / PgBouncer)
DATABASE_URL=postgresql://fadl_app:secret@localhost:5432/fadl_clinic_production
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# JWT (issued by identity-service / Keycloak)
# Asymmetric JWT (§2.1.4): base64 of the RS256 PUBLIC key PEM (see infra/jwt/README.md)
JWT_PUBLIC_KEY_B64=
# Dedicated secret for service-to-service tokens (NOT the user-token key)
SERVICE_JWT_SECRET=change-me-32-chars-minimum-secret!!
JWT_EXPIRY=15m

# Service identity
BRANCH_ID=1
SERVICE_NAME=file-service
