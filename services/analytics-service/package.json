{
  "name": "@fadl/analytics-service",
  "version": "0.0.1",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc --build",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "db:migrate": "node -e \"require('./dist/db/migrate')\"",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fadl/service-kit": "workspace:*",
    "@fadl/types": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "axios": "^1.16.0",
    "fastify": "^5.8.5",
    "pdfkit": "^0.15.0",
    "pino": "^8.19.0",
    "uuid": "^11.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.13.3",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
