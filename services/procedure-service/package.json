{
  "name": "@fadl/procedure-service",
  "version": "0.0.1",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc --build",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "db:migrate": "node -e \"require('./dist/db/migrate')\"",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fadl/types": "workspace:*",
    "fastify": "^5.8.5",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "pg": "^8.11.0",
    "zod": "^3.22.0",
    "uuid": "^9.0.0",
    "pino": "^8.19.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.0",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  }
}
