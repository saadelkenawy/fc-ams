# ─── Fadl Clinic — Production Secrets Template ────────────────────────────────
# Copy this file to .env and fill in every value.
# Generate random secrets with:  bash scripts/gen-secrets.sh
#
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# postgres user (keep "fadl" unless you changed infra/postgres/init.sql)
DB_USER=fadl
# Random strong password — min 32 chars. gen-secrets.sh sets this automatically.
DB_PASSWORD=

# ── PgBouncer ─────────────────────────────────────────────────────────────────
# MD5 hash of the DB password, used in infra/pgbouncer/userlist.txt.
# Format: md5<md5sum of "${DB_PASSWORD}${DB_USER}">
# gen-secrets.sh computes and writes this automatically.
PGBOUNCER_MD5_HASH=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Min 64 chars. gen-secrets.sh sets this automatically.
JWT_SECRET=
# Token lifetime — 15m is a sane default; increase to 1h for low-security envs.
JWT_EXPIRY=15m

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ACCESS_KEY=fadl_minio
MINIO_SECRET_KEY=
# Full public URL the browser uses to download files (must be reachable from users' browsers)
MINIO_PUBLIC_URL=https://files.yourdomain.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave blank to disable email delivery (notifications are logged only).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Fadl Clinic <noreply@fadlclinic.com>

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Leave blank to disable SMS delivery.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── AI Chatbot ────────────────────────────────────────────────────────────────
# Provide one of the two keys; Anthropic takes precedence if both are set.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Integration webhooks ──────────────────────────────────────────────────────
# Secret tokens used to verify inbound webhooks from each integration partner.
VIZITA_WEBHOOK_SECRET=
EKSHF_WEBHOOK_SECRET=
CLINIDO_WEBHOOK_SECRET=
INSTAPAY_WEBHOOK_SECRET=

# ── TLS / domain ──────────────────────────────────────────────────────────────
# The public domain the clinic will use. Used by nginx and CORS config.
DOMAIN=clinic.yourdomain.com
