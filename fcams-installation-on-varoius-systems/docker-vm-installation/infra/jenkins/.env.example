# Copy to .env and fill in values before running docker compose
# Never commit .env to git

JENKINS_ADMIN_PASSWORD=change_me_strong_password

# GitHub Personal Access Token
# Permissions: repo (full), admin:repo_hook
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Docker Hub Access Token (NOT your password)
# Create at: hub.docker.com → Account Settings → Personal access tokens
# Permissions: Read & Write
DOCKERHUB_TOKEN=dckr_pat_xxxxxxxxxxxxxxxxxxxx

# SSH private key for the 'deploy' user on pre-prod and prod servers
# Paste the full PEM block — newlines replaced with \n
# Example:  -----BEGIN OPENSSH PRIVATE KEY-----\nAAAA...\n-----END OPENSSH PRIVATE KEY-----
DEPLOY_SSH_KEY=
