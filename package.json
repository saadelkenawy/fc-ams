{
  "name": "fadl-clinic",
  "version": "0.0.1",
  "private": true,
  "description": "Fadl Clinic Management System — Enterprise healthcare platform",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r --parallel exec rm -rf dist node_modules",
    "db:migrate": "bash scripts/migrate.sh",
    "db:migrate:identity": "bash scripts/migrate.sh identity",
    "db:migrate:patient": "bash scripts/migrate.sh patient",
    "db:migrate:appointment": "bash scripts/migrate.sh appointment",
    "db:migrate:doctor": "bash scripts/migrate.sh doctor",
    "db:migrate:billing": "bash scripts/migrate.sh billing",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}
