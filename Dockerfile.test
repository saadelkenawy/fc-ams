# CI test runner — executes the money-path + RLS test suites against the
# stack's PostgreSQL (run with --network fcms_fadl-net; see Jenkinsfile Tests stage).
FROM node:20-alpine
WORKDIR /app
RUN npm install -g pnpm@8

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY shared/types/package.json ./shared/types/
COPY services/appointment-service/package.json ./services/appointment-service/
COPY services/billing-service/package.json ./services/billing-service/
RUN pnpm install --no-frozen-lockfile

COPY shared ./shared
COPY services/appointment-service ./services/appointment-service
COPY services/billing-service ./services/billing-service
RUN pnpm --filter @fadl/types build

CMD ["sh", "-c", "pnpm --filter @fadl/appointment-service test && pnpm --filter @fadl/billing-service test"]
