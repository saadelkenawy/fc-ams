# ─────────────────────────────────────────────────────────────
# Fadl Clinic – Demo Environment Variables
# Copy this file to .env.demo and fill in the values.
# Never commit .env.demo to version control.
# ─────────────────────────────────────────────────────────────

# Shared secret used to sign and verify all JWTs across services.
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-me-with-a-secure-random-string

# Subscription tier to apply by default to all demo users.
# Valid: basic | standard | premium
DEFAULT_TIER=standard

# Set to "true" to allow developer-minted JWTs to override the tier at runtime.
ALLOW_DEVELOPER_TOKEN_OVERRIDE=true

# ── Service database URLs (PgBouncer → PostgreSQL) ───────────
IDENTITY_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_identity
APPOINTMENT_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_appointments
PATIENT_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_patients
DOCTOR_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_doctors
BILLING_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_billing
EHR_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_ehr
AI_CHATBOT_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_ai_chatbot
ANALYTICS_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_analytics
PROCUREMENT_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_procurement
INTEGRATION_DATABASE_URL=postgres://fadl_app:password@localhost:5432/fadl_integration

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:replace-me-redis-password@localhost:6379

# ── External APIs ────────────────────────────────────────────
# OpenRouter key for the AI chatbot service (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-replace-me

# Twilio credentials for the notification service
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-me
TWILIO_FROM_NUMBER=+1234567890

# ── MinIO (file service) ─────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fadl-files

# ── Web portal (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_IDENTITY_API_URL=http://localhost:3000
NEXT_PUBLIC_APPOINTMENT_API_URL=http://localhost:3001
NEXT_PUBLIC_PATIENT_API_URL=http://localhost:3002
NEXT_PUBLIC_DOCTOR_API_URL=http://localhost:3003
NEXT_PUBLIC_BILLING_API_URL=http://localhost:3004
NEXT_PUBLIC_EHR_API_URL=http://localhost:3005
NEXT_PUBLIC_AI_CHATBOT_API_URL=http://localhost:3008
NEXT_PUBLIC_ANALYTICS_API_URL=http://localhost:3009
NEXT_PUBLIC_PROCUREMENT_API_URL=http://localhost:3010
NEXT_PUBLIC_INTEGRATION_API_URL=http://localhost:3012
